---
import Layout from '../../layouts/Layout.astro';

export const getStaticPaths = async () => {
	const posts = import.meta.glob('../../blog/*.mdx', { eager: true });

	return Object.entries(posts).map(([path, module]) => ({
		params: {
			post: path.split('/').pop()?.replace(/\.mdx$/, '')
		},
		props: module
	}));
};

const { Content, frontmatter } = Astro.props;
---

<Layout title={frontmatter.title}>
	<main class="post">
		<a class="text-[var(--ink)] no-underline" href="/">← Back to blog</a>
		<article class="mt-12 rounded-[1.25rem] border border-white/30 bg-white/[.07] p-[clamp(1.5rem,5vw,4rem)] shadow-[0_1.5rem_4rem_rgba(0,0,0,.1)] backdrop-blur-xl backdrop-saturate-[120%]">
			<Content />
		</article>
	</main>
</Layout>

<script>
	import mermaid from 'mermaid';

	mermaid.initialize({
		startOnLoad: false,
		theme: 'base',
		themeVariables: {
			background: 'transparent',
			primaryColor: '#211735',
			primaryBorderColor: '#a78bfa',
			primaryTextColor: '#f5f0ff',
			lineColor: '#b8a2ff',
			secondaryColor: '#151022',
			tertiaryColor: '#151022',
			fontFamily: 'Inter, ui-sans-serif, system-ui, sans-serif'
		},
		flowchart: { useMaxWidth: true, htmlLabels: true }
	});

	const diagrams = [...document.querySelectorAll('pre[data-language="mermaid"]')].map((codeBlock) => {
		const diagram = document.createElement('div');
		diagram.className = 'mermaid';
		diagram.textContent = codeBlock.textContent;
		codeBlock.replaceWith(diagram);
		return diagram;
	});

	if (diagrams.length) await mermaid.run({ nodes: diagrams });
</script>
